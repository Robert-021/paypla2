# Configuración para sitio estático en XAMPP
Options -Indexes
RewriteEngine On
RewriteBase /payivanplay/

# Manejar rutas de Next.js (quitar .html de la URL)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
